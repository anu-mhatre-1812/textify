# Supabase Configuration (from your Supabase project)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: TURN Server for better connectivity through firewalls
# Get free credentials from metered.ca or coturn
# This is optional - calls will work with Google's free STUN server,
# but TURN is needed for connections through strict firewalls
VITE_TURN_URLS=turn:relay.metered.ca:80,turn:relay.metered.ca:443
VITE_TURN_USERNAME=your-turn-username
VITE_TURN_CREDENTIAL=your-turn-credential
